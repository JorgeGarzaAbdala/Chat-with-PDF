<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Chat with PDF</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background-color: #EDE9E6;
    }

    .main-container {
      height: 80vh;
      display: flex;
      flex-direction: column;
    }

    .content {
      flex-grow: 1;
    }

    .message {
      padding: 10px;
      border-radius: 10px;
      margin-bottom: 10px;
      max-width: 80%;
    }

    .user {
      background-color: #C9996B;
      color: white;
      margin-left: auto;
    }

    .bot {
      background-color: #e9ecef;
      margin-right: auto;
    }

    #chatBox {
      flex-grow: 1;
      overflow-y: auto;
      min-height: 0;
    }
  </style>
</head>

<body>

<div class="container-fluid py-4 main-container">

  <% if (locals.showPdf) { %>

    <!-- CONTENT -->
    <div class="row align-items-stretch content">

      <!-- PDF -->
      <div class="col-md-7 d-flex">
        <div class="card shadow w-100">
          <div class="card-body d-flex flex-column">

            <h5>PDF Viewer</h5>

            <iframe 
              src="<%= pdfPath %>#toolbar=0&navpanes=0"
              class="w-100 flex-grow-1 border-0">
            </iframe>

            <form action="/upload" method="POST" enctype="multipart/form-data" 
                  class="mt-auto pt-3 border-top">
              <input type="file" name="pdf" class="form-control mb-2" required>
              <button class="btn btn-primary w-100">Upload PDF</button>
            </form>

          </div>
        </div>
      </div>

      <!-- CHAT -->
      <div class="col-md-5 d-flex">
        <div class="card shadow w-100">
          <div class="card-body d-flex flex-column">

            <h5> Chat</h5>

            <div id="chatBox">

              <% if (locals.chat && chat.length > 0) { %>
                <% chat.forEach(msg => { %>
                  <div class="d-flex <%= msg.role === 'user' ? 'justify-content-end' : 'justify-content-start' %>">
                    <div class="message <%= msg.role %>">
                      <%= msg.content %>
                    </div>
                  </div>
                <% }) %>
              <% } else { %>
                <p class="text-muted text-center mt-3">
                  Ask something about the PDF
                </p>
              <% } %>

            </div>

            <form action="/ask" method="POST" class="mt-2">
              <div class="input-group">
                <input type="text" name="question" class="form-control" placeholder="Ask..." required>
                <button class="btn btn-success">Ask</button>
              </div>
            </form>

          </div>
        </div>
      </div>

    </div>

    <!--  RESET SIEMPRE ABAJO -->
    <form action="/reset" method="GET" class="mt-3">
      <button class="btn btn-danger w-100">Reset</button>
    </form>

  <% } else { %>

    <div class="row content justify-content-center align-items-center">
      <div class="col-md-6">
        <div class="card shadow text-center">
          <div class="card-body">

            <h4 class="mb-3">📄 Upload a PDF to start</h4>

            <form action="/upload" method="POST" enctype="multipart/form-data">
              <input type="file" name="pdf" class="form-control mb-2" accept="application/pdf" required>
              <button class="btn btn-primary w-100">Upload PDF</button>
            </form>

          </div>
        </div>
      </div>
    </div>

  <% } %>

</div>

<script>
  const chatBox = document.getElementById("chatBox");
  if (chatBox) {
    chatBox.scrollTop = chatBox.scrollHeight;
  }
</script>

</body>
</html>